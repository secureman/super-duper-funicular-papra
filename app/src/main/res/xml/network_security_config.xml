<?xml version="1.0" encoding="utf-8"?>
<!--
  Papra is commonly self-hosted, sometimes on a local network without TLS
  (e.g. http://192.168.x.x:1221). This config allows cleartext traffic
  ONLY for user-supplied custom domains added at runtime via server settings,
  while everything else still requires HTTPS. Adjust/remove if you require
  strict HTTPS-only for your fork.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
